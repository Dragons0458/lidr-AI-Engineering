OPENAI_API_KEY=sk-proj-1234567890
ANTHROPIC_API_KEY=sk-ant-1234567890
GOOGLE_API_KEY=AIza1234567890
LLM_PROVIDER=openai
PRIMARY_MODEL=gpt-4o-mini
FALLBACK_MODEL=
LLM_TIMEOUT=30
LLM_RETRIES=2
REDIS_URL=redis://localhost:6379
# In docker-compose, REDIS_URL is overridden to redis://redis:6379
CACHE_TTL=86400
CACHE_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_ENABLED=true
# ~0.88 matches typical Spanish paraphrases; 0.92 is stricter (fewer false positives)
SEMANTIC_CACHE_THRESHOLD=0.88
SEMANTIC_CACHE_TTL=86400
SEMANTIC_CACHE_LOG_ONLY=false
INPUT_GUARDRAILS_ENABLED=true
OUTPUT_GUARDRAILS_ENABLED=true
CONVERSATION_MAX_TURNS=6
# Session 5 (off by default — existing endpoints unchanged until enabled)
TIER_RESOLUTION_ENABLED=false
MEMORY_COMPRESSION_ENABLED=false
ANCHOR_DETECTION_MODE=heuristic
COMPRESSION_MODEL=
CRITIC_MODEL=
BOSS_MAX_ITERATIONS=3
# Session 7 live — chunking strategies (contextual_retrieval needs ANTHROPIC_API_KEY)
PROPOSITIONAL_CHUNKER_MODEL=gpt-4o-mini
CONTEXTUAL_CHUNKER_MODEL=claude-sonnet-4-5
# Session 6 — ingestion catalog, Postgres, PII pseudonymization
DATABASE_URL=postgresql+psycopg://estimator:estimator@localhost:5433/estimator
CATALOG_PATH=data/catalog/catalog.yaml
INGESTION_DATA_ROOT=data/seed
PRESIDIO_SPACY_MODEL=es_core_news_md
PSEUDONYM_FAKER_LOCALE=es_ES
PSEUDONYM_HASH_SALT=change-me-in-prod
APP_ENV=development
LOG_LEVEL=DEBUG
