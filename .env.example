OPENAI_API_KEY=sk-proj-1234567890
ANTHROPIC_API_KEY=sk-ant-1234567890
GOOGLE_API_KEY=AIza1234567890
LLM_PROVIDER=openai
PRIMARY_MODEL=gpt-4o-mini
FALLBACK_MODEL=
LLM_TIMEOUT=600
LLM_RETRIES=2
REDIS_URL=redis://localhost:6379
# In docker-compose, REDIS_URL is overridden to redis://redis:6379
CACHE_TTL=86400
CACHE_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_ENABLED=true
# ~0.88 matches typical Spanish paraphrases; 0.92 is stricter (fewer false positives)
SEMANTIC_CACHE_THRESHOLD=0.88
SEMANTIC_CACHE_TTL=86400
SEMANTIC_CACHE_LOG_ONLY=false
INPUT_GUARDRAILS_ENABLED=true
OUTPUT_GUARDRAILS_ENABLED=true
CONVERSATION_MAX_TURNS=6
# Session 5 (off by default — existing endpoints unchanged until enabled)
TIER_RESOLUTION_ENABLED=false
MEMORY_COMPRESSION_ENABLED=false
ANCHOR_DETECTION_MODE=heuristic
COMPRESSION_MODEL=
CRITIC_MODEL=
BOSS_MAX_ITERATIONS=3
# Session 7 live — chunking strategies (contextual_retrieval needs ANTHROPIC_API_KEY)
PROPOSITIONAL_CHUNKER_MODEL=gpt-4o-mini
CONTEXTUAL_CHUNKER_MODEL=claude-sonnet-4-5
# Session 9 — RAG end-to-end (transcript → grounded estimate)
# gpt-5/gpt-5-mini require a verified OpenAI org; use gpt-4o-mini or gemini/* otherwise.
RETRIEVAL_API_KEY=demo-retrieval-key
ESTIMATE_API_KEY=demo-estimate-key
REFORMULATION_MODEL=gpt-4o-mini
GENERATION_MODEL=gpt-4o-mini
GENERATION_REASONING_EFFORT=minimal
GENERATION_MAX_TOKENS=64000
RETRIEVAL_TOP_K=10
RETRIEVAL_DISTANCE_THRESHOLD=0.6
MAX_CONTEXT_TOKENS=16384
IDEMPOTENCY_TTL=86400
# Session 10 — hybrid search + cross-encoder reranking
RETRIEVAL_SEARCH_MODE=vector
RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/mmarco-mMiniLMv2-L12-H384-v1
RETRIEVAL_RECALL_TOP_K=50
RERANK_TOP_N=5
RRF_K=60
# Session 10 live — advanced retrieval pipeline
RETRIEVAL_ROUTING_ENABLED=true
QUERY_TRANSFORM_ENABLED=true
TEMPORAL_DECAY_ENABLED=false
ROUTER_MODEL=gpt-4o-mini
QUERY_TRANSFORM_MODEL=gpt-4o-mini
TEMPORAL_DECAY_HALF_LIFE_DAYS=900
QUERY_MAX_SUBQUERIES=4
ROUTER_MAX_TARGETS=3
TASK_HOURS_TOP_K=5
TASK_HOURS_DISTANCE_THRESHOLD=0.45
# Session 6 — ingestion catalog, Postgres, PII pseudonymization
DATABASE_URL=postgresql+psycopg://estimator:estimator@localhost:5433/estimator
CATALOG_PATH=data/catalog/catalog.yaml
INGESTION_DATA_ROOT=data/seed
PRESIDIO_SPACY_MODEL=es_core_news_md
PSEUDONYM_FAKER_LOCALE=es_ES
HALLUCINATION_NUMERIC_TOLERANCE=0.5
# Session 12 — hand-written estimation agent (Responses API)
AGENT_MODEL=gpt-5
AGENT_REASONING_EFFORT=medium
AGENT_MAX_ITERATIONS=10
AGENT_SEARCH_TOP_K=5
AGENT_SEARCH_DISTANCE_THRESHOLD=0.45
AGENT_RECOVERY_RELIABILITY_THRESHOLD=0.35
STREAMLIT_DEFAULT_HOURLY_RATE_EUR=75
STREAMLIT_AGENT_AVATAR_MAX_BYTES=2097152
# Session 13 — LangGraph orchestration + Logfire (token optional for local)
LANGGRAPH_ENABLED=true
LOGFIRE_TOKEN=
LOGFIRE_SERVICE_NAME=estimador-cag
APP_ENV=development
LOG_LEVEL=DEBUG
