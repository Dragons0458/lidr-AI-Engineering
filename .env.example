OPENAI_API_KEY=sk-proj-1234567890
ANTHROPIC_API_KEY=sk-ant-1234567890
GOOGLE_API_KEY=AIza1234567890
LLM_PROVIDER=openai
PRIMARY_MODEL=gpt-4o-mini
FALLBACK_MODEL=
LLM_TIMEOUT=30
LLM_RETRIES=2
REDIS_URL=redis://localhost:6379
# In docker-compose, REDIS_URL is overridden to redis://redis:6379
CACHE_TTL=86400
CACHE_ENABLED=true
EMBEDDING_MODEL=text-embedding-3-small
SEMANTIC_CACHE_ENABLED=true
# ~0.88 matches typical Spanish paraphrases; 0.92 is stricter (fewer false positives)
SEMANTIC_CACHE_THRESHOLD=0.88
SEMANTIC_CACHE_TTL=86400
SEMANTIC_CACHE_LOG_ONLY=false
INPUT_GUARDRAILS_ENABLED=true
OUTPUT_GUARDRAILS_ENABLED=true
APP_ENV=development
LOG_LEVEL=DEBUG
